{
  "name": "opendeck",
  "version": "0.0.0",
  "description": "Turn any phone, tablet, or spare screen into a zero-lag control deck for AI coding agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "opendeck": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai-agents",
    "control-deck",
    "pwa",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/himanshudongre/opendeck.git",
    "directory": "packages/hub"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts --demo",
    "build": "tsup && node scripts/copy-deck.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.211",
    "@fastify/static": "^10.1.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fastify": "^5.10.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^5.5.0",
    "ws": "^8.21.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@opendeck/protocol": "workspace:*",
    "@opendeck/simulator": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "vitest": "^4.1.10"
  }
}
